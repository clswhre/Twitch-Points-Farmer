{
  "manifest_version": 3,
  "name": "Tangerine",
  "version": "1.0.0",
  "description": "Love skins. Hate farming",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "tangerine.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "*://*.twitch.tv/*"
  ],
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "48": "tangerine.png"
  }
}
