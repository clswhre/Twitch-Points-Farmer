{
  "manifest_version": 3,
  "name": "Twitch Farmer",
  "version": "1.0.0",
  "description": "Love skins. Hate farming",
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"]
    }
  ],
  
  "icons": {
    "48": "icon.png"
  }
}
